# ==============================================================================
# Copy to benchmark/benchmark.env and fill in external IPs, then run:
#   python3 benchmark/run_benchmark.py
#
# CLI flags (--unified-endpoint, etc.) override these values when provided.
# ==============================================================================

UNIFIED_ENDPOINT="http://<unified-node-external-ip>"
DISAGGREGATED_ENDPOINT="http://<cpu-node-external-ip>:8000"

# Optional overrides (defaults match run_benchmark.py)
# REQUESTS_PER_WORKER=5
# INPUT_TOKENS=256
# OUTPUT_TOKENS=256
