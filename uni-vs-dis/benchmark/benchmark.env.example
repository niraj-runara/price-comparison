# ==============================================================================
# Benchmark endpoints.
#
# RTX baseline (Vast.ai): keep this SSH tunnel open while benchmarking:
#   ssh -p 19270 root@99.148.65.9 -L 8080:localhost:8080
# Then UNIFIED_ENDPOINT is the local forward to the Vast SGLang server.
#
# Disaggregated (GCP): cpu-node external IP (or :8000 on the router).
# ==============================================================================

UNIFIED_ENDPOINT="http://127.0.0.1:8080"
DISAGGREGATED_ENDPOINT="http://<cpu-node-external-ip>:8000"

# Optional overrides
# REQUESTS_PER_WORKER=5
# INPUT_TOKENS=256
# OUTPUT_TOKENS=256
