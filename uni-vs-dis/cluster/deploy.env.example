# ==============================================================================
# Copy to cluster/deploy.env and fill in your GCP project, zone, and instance
# names (from runara-base-sglang VMs). Then run:
#   ./cluster/deploy.sh
#
# deploy.sh renders config/cluster.env (see config/cluster.env.example), pushes
# startup scripts, and brings the cluster up (prefill → decode → router).
#
# Hardware (see README):
#   unified-node  = g4-standard-48 (1x RTX PRO 6000), tp-size 1
#   prefill-node  = g2-standard-48 (4x L4), tp-size 4
#   decode-node   = g2-standard-48 (4x L4), tp-size 4
#
# Only instance NAMES are needed — not IPs. Nodes reach each other via GCP
# internal DNS (short hostname in the same VPC).
# ==============================================================================

PROJECT_ID="main-entropy-495701-p6"
ZONE="us-central1-a"

CPU_NODE="cpu-node"
PREFILL_NODE="prefill-node"
DECODE_NODE="decode-node"

# Unified baseline for benchmarking (g4-standard-48, 1x RTX PRO 6000).
# Leave blank to skip unified-node setup in deploy.sh.
UNIFIED_NODE="unified-node"
