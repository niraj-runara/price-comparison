# ==============================================================================
# Copy to cluster/deploy.env and fill in project, zone, and instance names.
# Then run: ./cluster/deploy.sh
#
# Hardware:
#   unified-rtx-node = g4-standard-48 (1x RTX PRO 6000), tp-size 1  — baseline
#   unified-l4-node  = g2-standard-48 (4x L4), tp-size 4
# ==============================================================================

PROJECT_ID="main-entropy-495701-p6"
ZONE="us-central1-a"

UNIFIED_RTX_NODE="unified-rtx-node"
UNIFIED_L4_NODE="unified-l4-node"
